# Replit configuration for Network Anomaly Detector

run = "python api.py"

[env]
PYTHON_VERSION = "3.10"
FLASK_ENV = "production"
FLASK_APP = "api.py"

[packager]
language = "python3"

[packager.features]
packageSearch = true

[[ports]]
localPort = 8000
externalPort = 80

# Deployment configuration (used when you click "Publish"/"Deploy").
# Runs the app with a production WSGI server bound to the expected port 8000.
[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:8000", "--timeout", "120", "--workers", "1", "api:app"]
