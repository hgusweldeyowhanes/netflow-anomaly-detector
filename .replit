# Replit configuration for Network Anomaly Detector

run = "python api.py"

[env]
PYTHON_VERSION = "3.10"
FLASK_ENV = "production"
FLASK_APP = "api.py"

[packager]
language = "python3"

[packager.features]
packageSearch = true

[[ports]]
localPort = 8000
externalPort = 80

# Deployment configuration (used when you click "Publish"/"Deploy").
# The build step installs Python dependencies into the deployment image;
# the run step starts a production WSGI server bound to the expected port 8000.
[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "pip install -r requirements.txt"]
run = ["gunicorn", "--bind", "0.0.0.0:8000", "--timeout", "120", "--workers", "1", "api:app"]
